    {
      "mode": "managed",
      "type": "google_workflows_workflow",
      "name": "nexus_workflow",
      "provider": "provider[\"registry.terraform.io/hashicorp/google\"]",
      "instances": [
        {
          "schema_version": 1,
          "attributes": {
            "call_log_level": "",
            "create_time": "2026-04-08T12:20:31.010608876Z",
            "crypto_key_name": "",
            "deletion_protection": true,
            "description": "",
            "effective_labels": {
              "goog-terraform-provisioned": "true"
            },
            "execution_history_level": "",
            "id": "projects/nexus-stream-project/locations/us-central1/workflows/nexus-main-workflow",
            "labels": {},
            "name": "nexus-main-workflow",
            "name_prefix": null,
            "project": "nexus-stream-project",
            "region": "us-central1",
            "revision_id": "000005-a3f",
            "service_account": "projects/nexus-stream-project/serviceAccounts/nexus-stream-sa@nexus-stream-project.iam.gserviceaccount.com",
            "source_contents": "main:\r\n  steps:\r\n    - init:\r\n        assign:\r\n          - project_id: ${sys.get_env(\"GOOGLE_CLOUD_PROJECT_ID\")}\r\n          - bucket_name: \"nexus-stream-project-nexus-raw-data\"\r\n          - city: \"Sao Paulo\"\r\n          - current_time: ${string(int(sys.now()))}\r\n\r\n    - get_secret:\r\n        call: googleapis.secretmanager.v1.projects.secrets.versions.access\r\n        args:\r\n          name: ${\"projects/\" + project_id + \"/secrets/openweathermap-api-key/versions/latest\"}\r\n        result: secret_response\r\n\r\n    - decode_secret:\r\n        assign:\r\n          - api_key: ${text.decode(base64.decode(secret_response.payload.data))}\r\n\r\n    - fetch_weather_data:\r\n        call: http.get\r\n        args:\r\n          url: \"https://api.openweathermap.org/data/2.5/weather\"\r\n          query:\r\n            q: ${city}\r\n            appid: ${api_key}\r\n            units: \"metric\"\r\n        result: weather_response\r\n\r\n    - save_to_raw_storage:\r\n        call: googleapis.storage.v1.objects.insert\r\n        args:\r\n          bucket: ${bucket_name}\r\n          name: ${\"ingestion/weather/\" + current_time + \".json\"}\r\n          body: ${weather_response.body}\r\n\r\n    - finish:\r\n        return:\r\n          message: \"Ingestão realizada com sucesso\"\r\n          file_saved: ${\"ingestion/weather/\" + current_time + \".json\"}\r\n          # Corrigido de .status para .code\r\n          http_code: ${weather_response.code}\r\n",
            "state": "ACTIVE",
            "tags": null,
            "terraform_labels": {
              "goog-terraform-provisioned": "true"
            },
            "timeouts": null,
            "update_time": "2026-04-08T14:20:22.037112268Z",
            "user_env_vars": {}
          },
          "sensitive_attributes": [],
          "identity_schema_version": 0,
          "private": "eyJlMmJmYjczMC1lY2FhLTExZTYtOGY4OC0zNDM2M2JjN2M0YzAiOnsiY3JlYXRlIjoxMjAwMDAwMDAwMDAwLCJkZWxldGUiOjEyMDAwMDAwMDAwMDAsInVwZGF0ZSI6MTIwMDAwMDAwMDAwMH0sInNjaGVtYV92ZXJzaW9uIjoiMSJ9",
          "dependencies": [
            "google_project_iam_member.eventarc_receiver",
            "google_project_iam_member.secret_accessor",
            "google_project_iam_member.workflow_invoker",
            "google_service_account.function_sa",
            "time_sleep.wait_iam_propagation"
